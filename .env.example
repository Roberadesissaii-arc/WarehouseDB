# WarehouseDB — copy to WarehouseDB/.env

# Use FLASK_ENV=production on real deployments. In production the server refuses
# to start with the default SECRET_KEY / STORE_API_KEY / SCAN_API_KEY below.
FLASK_ENV=development
SECRET_KEY=change-me-use-a-long-random-string
# DATABASE=
HOST=0.0.0.0
PORT=8000
# Must be changed for production — these are insecure defaults.
STORE_API_KEY=store-dev-key
SCAN_API_KEY=scan-dev-key
SCAN_PUBLIC_URL=http://localhost:5002
# Set to true when serving behind HTTPS so the session cookie is TLS-only.
SESSION_COOKIE_SECURE=false
# Number of trusted reverse proxies in front of the app (e.g. 1 behind
# Cloudflare). 0 means direct access; X-Forwarded-For is ignored so client IPs
# used for login throttling and the IP allowlist cannot be spoofed.
TRUST_PROXY=0

# Docker Compose (optional — when running docker compose from WarehouseDB/)
# STORE_SECRET_KEY=change-me-store-secret
# SCAN_SECRET_KEY=change-me-scan-secret
# STORE_PORT=5001
# SCAN_PORT=5002
